generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────────────────
// Role values: CLIENT | COMPANY_ADMIN | ENGINEER | SALES | OPS | ADMIN

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String?
  firstName        String
  lastName         String
  phone            String?
  role             String    @default("CLIENT")
  language         String    @default("sq")
  companyId        String?
  company          Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  emailVerified    DateTime?
  verifyToken      String?
  resetToken       String?
  resetTokenExpiry DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tickets         Ticket[]         @relation("TicketCreator")
  assignedTickets Ticket[]         @relation("TicketAssignee")
  comments        TicketComment[]
  ticketHistories TicketHistory[]
  orders          Order[]
  quotes          Quote[]
  notifications   Notification[]
  auditLogs       AuditLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Companies ───────────────────────────────────────────────────────────────
// tier values: RETAIL | B2B

model Company {
  id         String   @id @default(cuid())
  name       String
  vatNumber  String?
  address    String?
  city       String?
  country    String   @default("Albania")
  tier       String   @default("RETAIL")
  isApproved Boolean  @default(false)
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users   User[]
  tickets Ticket[]
  quotes  Quote[]
  orders  Order[]

  @@map("companies")
}

// ─── Ticketing ───────────────────────────────────────────────────────────────
// status values: OPEN | ASSIGNED | IN_PROGRESS | PAUSED | PENDING_CLIENT | RESOLVED | CLOSED
// priority values: LOW | MEDIUM | HIGH | CRITICAL

model Ticket {
  id           String   @id @default(cuid())
  number       String   @unique
  title        String
  description  String   @db.Text
  status       String   @default("OPEN")
  priority     String   @default("MEDIUM")
  division     String
  slaDeadline  DateTime?
  slaWarned    Boolean  @default(false)
  slaBreached  Boolean  @default(false)
  resolvedAt   DateTime?
  closedAt     DateTime?
  rating       Int?
  ratingNote   String?
  createdById  String
  assignedToId String?
  companyId    String?
  /// Estimated additional hours; with estimatedDays drives slaDeadline from createdAt (8h per day + hours, wall-clock).
  estimatedHours         Int?
  /// Estimated working days; each day counts as 8 hours toward SLA deadline from createdAt.
  estimatedDays          Int?
  /// When the requester has no portal account (admin-created ticket).
  externalRequesterName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy  User            @relation("TicketCreator", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedTo User?           @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  company    Company?        @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  comments   TicketComment[]
  history    TicketHistory[]

  @@map("tickets")
}

model TicketComment {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  body        String   @db.Text
  /// true = staff-only internal note; false = external (visible to the ticket requester in the portal).
  isInternal  Boolean  @default(false)
  attachments String   @default("[]") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ticket_comments")
}

model TicketHistory {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedById String
  changedBy   User     @relation(fields: [changedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  field       String
  oldValue    String?
  newValue    String?
  createdAt   DateTime @default(now())

  @@map("ticket_history")
}

// ─── Orders ──────────────────────────────────────────────────────────────────
// status values: PLACED | CONFIRMED | DISPATCHED | DELIVERED | CANCELLED
//
// Product line items are JSON (references shop catalog SKUs on SQL Server; no FK here).

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items           String   @db.Text
  subtotal        Decimal  @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)
  status          String   @default("PLACED")
  deliveryAddress String
  deliveryCity    String
  deliveryNotes   String?
  contactPhone    String
  staffNotes      String?
  confirmedAt     DateTime?
  dispatchedAt    DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("orders")
}

// ─── Quotes (B2B) ────────────────────────────────────────────────────────────
// status values: PENDING | REVIEWING | SENT | ACCEPTED | REJECTED | REVISION_REQUESTED

model Quote {
  id             String    @id @default(cuid())
  quoteNumber    String    @unique
  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  requestedById  String
  requestedBy    User      @relation(fields: [requestedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyName    String
  contactName    String
  contactEmail   String
  contactPhone   String?
  vatNumber      String?
  title          String
  description    String    @db.Text
  services       String    @default("[]") @db.Text
  timeline       String?
  attachments    String    @default("[]") @db.Text
  status         String    @default("PENDING")
  lineItems      String?   @db.Text
  subtotal       Decimal?  @db.Decimal(10, 2)
  discount       Decimal?  @db.Decimal(10, 2)
  total          Decimal?  @db.Decimal(10, 2)
  pdfUrl         String?
  validUntil     DateTime?
  clientNote     String?   @db.Text
  internalNote   String?   @db.Text
  respondedAt    DateTime?
  followUpSentAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("quotes")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  titleEn   String?
  body      String    @db.Text
  bodyEn    String?   @db.Text
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("notifications")
}

// ─── Audit Logs (ISO 27001) ──────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  action     String
  resource   String
  resourceId String?
  ip         String?
  userAgent  String?
  metadata   String?  @db.Text
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  titleSq     String
  titleEn     String
  bodySq      String    @db.Text
  bodyEn      String    @db.Text
  excerptSq   String?
  excerptEn   String?
  coverImage  String?
  category    String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  authorId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

// ─── Email Templates ─────────────────────────────────────────────────────────

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  subjectSq String
  subjectEn String
  bodySq    String   @db.Text
  bodyEn    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}
