generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────────────────
// Role values: CLIENT | COMPANY_ADMIN | ENGINEER | SALES | OPS | PARTNER | ADMIN

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String?
  firstName        String
  lastName         String
  phone            String?
  role             String    @default("CLIENT")
  language         String    @default("sq")
  companyId        String?
  company          Company?  @relation("UserActiveCompany", fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// Company record created at self-registration (immutable; preserved when admin reassigns active company).
  registeredCompanyId String?
  registeredCompany   Company?  @relation("UserRegisteredCompany", fields: [registeredCompanyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /// Optional company fields entered at signup (immutable snapshot).
  registrationCompanySnapshot Json?
  emailVerified    DateTime?
  verifyToken      String?
  resetToken       String?
  resetTokenExpiry DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorSecret  String?
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  /// Set when an admin removes a staff member; account stays for historical FK references.
  deletedAt        DateTime?
  /// Optional per-user admin area overrides (read/write). Null = use role defaults.
  adminAclJson     Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tickets         Ticket[]         @relation("TicketCreator")
  assignedTickets Ticket[]         @relation("TicketAssignee")
  comments        TicketComment[]
  ticketHistories TicketHistory[]
  orders          Order[]
  quotes          Quote[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  projectsCreated Project[]        @relation("ProjectCreator")
  projectMembers  ProjectMember[]
  projectMessages ProjectMessage[]
  projectClients  ProjectClient[]
  projectStepsCreated ProjectStep[] @relation("ProjectStepCreator")
  conversationsCreated Conversation[]        @relation("ConversationCreator")
  conversationParticipants ConversationParticipant[]
  conversationMessages ConversationMessage[] @relation("ConversationMessageAuthor")
  staffDailyReports StaffDailyReport[]
  staffDailyReportReplies StaffDailyReportReply[] @relation("StaffDailyReportReplyAuthor")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Companies ───────────────────────────────────────────────────────────────
// tier values: RETAIL | B2B

model Company {
  id         String   @id @default(cuid())
  name       String
  vatNumber  String?
  address    String?
  city       String?
  country    String   @default("Albania")
  tier       String   @default("RETAIL")
  isApproved Boolean  @default(false)
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users              User[]          @relation("UserActiveCompany")
  registeredUsers    User[]          @relation("UserRegisteredCompany")
  tickets        Ticket[]
  quotes         Quote[]
  orders         Order[]
  projectClients ProjectClient[]

  @@index([name])
  @@index([vatNumber])
  @@map("companies")
}

// ─── Ticketing ───────────────────────────────────────────────────────────────
// status values: OPEN | ASSIGNED | IN_PROGRESS | PAUSED | PENDING_CLIENT | RESOLVED | CLOSED
// priority values: LOW | MEDIUM | HIGH | CRITICAL

model Ticket {
  id           String   @id @default(cuid())
  number       String   @unique
  title        String
  description  String   @db.Text
  status       String   @default("OPEN")
  priority     String   @default("MEDIUM")
  division     String
  slaDeadline  DateTime?
  slaWarned    Boolean  @default(false)
  slaBreached  Boolean  @default(false)
  resolvedAt   DateTime?
  closedAt     DateTime?
  rating       Int?
  ratingNote   String?
  createdById  String
  assignedToId String?
  companyId    String?
  projectId    String?
  /// Estimated additional hours; with estimatedDays drives slaDeadline from createdAt (24h per calendar day + hours, wall-clock).
  estimatedHours         Int?
  /// Estimated calendar days; each day counts as 24 hours toward SLA deadline from createdAt.
  estimatedDays          Int?
  /// When the requester has no portal account (admin-created ticket).
  externalRequesterName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy  User            @relation("TicketCreator", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedTo User?           @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  company    Company?        @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project    Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  comments   TicketComment[]
  history    TicketHistory[]

  @@index([projectId])
  @@map("tickets")
}

// ─── Projects ────────────────────────────────────────────────────────────────
// status: ACTIVE | COMPLETED | ARCHIVED
// member access: read | write | admin

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?  @db.Text
  status      String   @default("ACTIVE")
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User             @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  members   ProjectMember[]
  clients   ProjectClient[]
  tickets        Ticket[]
  messages       ProjectMessage[]
  steps          ProjectStep[]
  conversation   Conversation?

  @@index([status])
  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  access    String   @default("read")
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectClient {
  id        String  @id @default(cuid())
  projectId String
  companyId String?
  userId    String?
  /// Display name when not linked to a portal user or company (name-only client).
  label     String?
  createdAt DateTime @default(now())

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([projectId])
  @@map("project_clients")
}

model ProjectMessage {
  id          String   @id @default(cuid())
  projectId   String
  authorId    String
  body        String   @db.Text
  isInternal  Boolean  @default(false)
  attachments String   @default("[]") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([projectId, createdAt])
  @@map("project_messages")
}

model ProjectStep {
  id            String   @id @default(cuid())
  projectId     String
  sortOrder     Int      @default(0)
  title         String
  description   String?  @db.Text
  status        String   @default("OPEN")
  clientVisible Boolean  @default(false)
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ProjectStepCreator", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([projectId, sortOrder])
  @@map("project_steps")
}

// ─── Conversations (admin messaging) ─────────────────────────────────────────

model Conversation {
  id            String    @id @default(cuid())
  type          String    // PROJECT | DIRECT | GROUP
  title         String?
  projectId     String?   @unique
  createdById   String
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project      Project?                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy    User                      @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  participants ConversationParticipant[]
  messages     ConversationMessage[]

  @@index([type, lastMessageAt])
  @@index([createdById])
  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  role           String    @default("member") // member | admin
  lastReadAt     DateTime?
  joinedAt       DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model ConversationMessage {
  id             String   @id @default(cuid())
  conversationId String
  authorId       String
  body           String   @db.Text
  isInternal     Boolean  @default(false)
  attachments    String   @default("[]") @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User         @relation("ConversationMessageAuthor", fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}

model TicketComment {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  body        String   @db.Text
  /// true = staff-only internal note; false = external (visible to the ticket requester in the portal).
  isInternal  Boolean  @default(false)
  attachments String   @default("[]") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ticket_comments")
}

model TicketHistory {
  id          String   @id @default(cuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedById String
  changedBy   User     @relation(fields: [changedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  field       String
  oldValue    String?
  newValue    String?
  createdAt   DateTime @default(now())

  @@map("ticket_history")
}

// ─── Orders ──────────────────────────────────────────────────────────────────
// status values: PLACED | CONFIRMED | DISPATCHED | DELIVERED | CANCELLED
//
// Product line items are JSON (references shop catalog SKUs on SQL Server; no FK here).

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items           String   @db.Text
  subtotal        Decimal  @db.Decimal(10, 2)
  total           Decimal  @db.Decimal(10, 2)
  status          String   @default("PLACED")
  deliveryAddress String
  deliveryCity    String
  deliveryNotes   String?
  contactPhone    String
  staffNotes      String?
  confirmedAt     DateTime?
  dispatchedAt    DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("orders")
}

// ─── Quotes (B2B) ────────────────────────────────────────────────────────────
// status values: PENDING | REVIEWING | SENT | ACCEPTED | REJECTED | REVISION_REQUESTED

model Quote {
  id             String    @id @default(cuid())
  quoteNumber    String    @unique
  companyId      String?
  company        Company?  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  requestedById  String
  requestedBy    User      @relation(fields: [requestedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyName    String
  contactName    String
  contactEmail   String
  contactPhone   String?
  vatNumber      String?
  title          String
  description    String    @db.Text
  services       String    @default("[]") @db.Text
  timeline       String?
  attachments    String    @default("[]") @db.Text
  status         String    @default("PENDING")
  lineItems      String?   @db.Text
  subtotal       Decimal?  @db.Decimal(10, 2)
  discount       Decimal?  @db.Decimal(10, 2)
  total          Decimal?  @db.Decimal(10, 2)
  pdfUrl         String?
  validUntil     DateTime?
  clientNote     String?   @db.Text
  internalNote   String?   @db.Text
  respondedAt    DateTime?
  followUpSentAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("quotes")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  titleEn   String?
  body      String    @db.Text
  bodyEn    String?   @db.Text
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("notifications")
}

// ─── Audit Logs (ISO 27001) ──────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  action     String
  resource   String
  resourceId String?
  ip         String?
  userAgent  String?
  metadata   String?  @db.Text
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  titleSq     String
  titleEn     String
  bodySq      String    @db.Text
  bodyEn      String    @db.Text
  excerptSq   String?
  excerptEn   String?
  coverImage  String?
  category    String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  authorId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("blog_posts")
}

// ─── Shop catalog overlays (Financa5 remains source of truth for prices/stock/names) ─

/// Editable shop presentation keyed by Financa5 ARTIKUJ.KOD (`ShopProduct.id` / `sku`).
model ShopProductOverlay {
  erpKod         String   @id
  imagesJson     String   @default("[]") @db.Text
  descriptionSq  String?  @db.Text
  descriptionEn  String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("shop_product_overlays")
}

// ─── Email Templates ─────────────────────────────────────────────────────────

model EmailTemplate {
  id        String   @id @default(cuid())
  key       String   @unique
  subjectSq String
  subjectEn String
  bodySq    String   @db.Text
  bodyEn    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

// ─── Admin report presets / schedules / share links ───────────────────────────

model ReportPreset {
  id          String   @id @default(cuid())
  name        String
  createdById String
  configJson  Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  schedules ReportSchedule[]
  shares    ReportShareLink[]

  @@map("report_presets")
}

model ReportSchedule {
  id          String    @id @default(cuid())
  presetId    String
  preset      ReportPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  cron        String
  recipients  String    @db.Text
  lastRunAt   DateTime?
  enabled     Boolean   @default(true)
  createdById String
  createdAt   DateTime  @default(now())

  @@map("report_schedules")
}

model ReportShareLink {
  id          String    @id @default(cuid())
  presetId    String?
  preset      ReportPreset? @relation(fields: [presetId], references: [id], onDelete: SetNull)
  paramsJson  Json
  token       String    @unique
  expiresAt   DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  @@map("report_share_links")
}

// ─── Admin document templates & contracts ─────────────────────────────────────

model DocumentTemplate {
  id              String   @id @default(cuid())
  name            String
  type            String
  language        String   @default("sq")
  bodyMarkdown    String   @db.Text
  bodyMarkdownSq  String   @db.Text
  bodyMarkdownEn  String   @db.Text
  defaultLanguage String   @default("sq")
  sectionsJson    Json?
  isDefault       Boolean  @default(false)
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  documents ContractDocument[]

  @@index([type])
  @@map("document_templates")
}

model ContractDocument {
  id             String    @id @default(cuid())
  documentNumber String    @unique
  type           String
  status         String    @default("DRAFT")
  language       String    @default("sq")
  templateId     String?
  template       DocumentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  partyJson      Json
  payloadJson    Json
  pdfUrl         String?
  pdfGeneratedAt DateTime?
  createdById    String
  updatedById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([type, status])
  @@index([createdById])
  @@index([createdAt])
  @@map("contract_documents")
}

model TemplateSettings {
  id        String   @id @default("default")
  configJson Json
  updatedAt DateTime @updatedAt

  @@map("template_settings")
}

// ─── Public site CMS (admin Settings) ─────────────────────────────────────────

model SiteSettings {
  id           String   @id @default("default")
  generalJson  Json
  brandingJson Json
  heroJson     Json
  contactJson  Json
  socialJson   Json
  footerJson   Json
  seoJson      Json
  landingJson  Json
  updatedAt    DateTime @updatedAt

  @@map("site_settings")
}

model MarketingService {
  id             String   @id @default(cuid())
  slug           String   @unique
  sortOrder      Int      @default(0)
  enabled        Boolean  @default(true)
  featured       Boolean  @default(false)
  nameSq         String
  nameEn         String
  shortDescSq    String   @db.Text
  shortDescEn    String   @db.Text
  fullDescSq     String?  @db.Text
  fullDescEn     String?  @db.Text
  iconKey        String   @default("Monitor")
  imageUrl       String?
  bannerUrl      String?
  ctaTextSq      String?
  ctaTextEn      String?
  ctaLink        String?
  showOnHomepage Boolean  @default(true)
  cardStyle      String?
  gradientClass  String?
  hoverEffect    String?
  colorClass     String?
  accentClass    String?
  metaTitleSq    String?
  metaTitleEn    String?
  metaDescSq     String?
  metaDescEn     String?
  keywordsSq     String?
  keywordsEn     String?
  featuresJson   Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([enabled, sortOrder])
  @@map("marketing_services")
}

model Testimonial {
  id          String   @id @default(cuid())
  sortOrder   Int      @default(0)
  enabled     Boolean  @default(true)
  featured    Boolean  @default(false)
  clientName  String
  roleSq      String?
  roleEn      String?
  companySq   String?
  companyEn   String?
  reviewSq    String   @db.Text
  reviewEn    String   @db.Text
  rating      Int      @default(5)
  imageUrl    String?
  avatarColor String?
  initials    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled, sortOrder])
  @@map("testimonials")
}

// ─── Staff daily reports (admin calendar) ────────────────────────────────────

model StaffDailyReport {
  id         String   @id @default(cuid())
  userId     String
  reportDate DateTime @db.Date
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  replies StaffDailyReportReply[]

  @@unique([userId, reportDate])
  @@index([reportDate])
  @@map("staff_daily_reports")
}

model StaffDailyReportReply {
  id        String   @id @default(cuid())
  reportId  String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  report StaffDailyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  author User             @relation("StaffDailyReportReplyAuthor", fields: [authorId], references: [id], onDelete: NoAction)

  @@index([reportId, createdAt])
  @@map("staff_daily_report_replies")
}
